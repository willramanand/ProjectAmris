{
  "name": "@willramanand/amris",
  "version": "0.2.0",
  "type": "module",
  "description": "Amris web component library.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/willramanand/ProjectQuartz.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "main": "./dist/amris.js",
  "module": "./dist/amris.js",
  "types": "./dist/index.all.d.ts",
  "customElements": "dist/custom-elements.json",
  "exports": {
    ".": {
      "types": "./dist/index.all.d.ts",
      "import": "./dist/amris.js"
    },
    "./core": {
      "types": "./dist/index.d.ts",
      "import": "./dist/amris-core.js"
    },
    "./components/*": {
      "types": "./dist/components/*/index.d.ts",
      "import": "./dist/components/*/index.js"
    },
    "./styles/*": {
      "types": "./dist/styles/*.d.ts",
      "import": "./dist/styles/*.js"
    },
    "./styles/tokens.css": "./dist/styles/tokens.css",
    "./tokens": {
      "types": "./dist/tokens/index.d.ts",
      "import": "./dist/tokens/index.js"
    },
    "./utilities/*": {
      "types": "./dist/utilities/*.d.ts",
      "import": "./dist/utilities/*.js"
    },
    "./custom-elements.json": "./dist/custom-elements.json",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "./dist/amris.js",
    "./dist/amris-core.js",
    "./dist/components/**/*.js",
    "./dist/chunks/**/*.js"
  ],
  "scripts": {
    "dev": "vite --host",
    "build": "tsc && vite build && tsc -p tsconfig.types.json && npm run build:manifest && npm run build:tokens-css",
    "build:manifest": "cem analyze --config custom-elements-manifest.config.js",
    "build:tokens-css": "node scripts/build-tokens-css.mjs",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "npm run build && changeset publish",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:a11y": "vitest run test/a11y.test.ts",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@lit-labs/rollup-plugin-minify-html-literals": "^0.1.1",
    "@storybook/web-components": "^10.3.0",
    "@storybook/web-components-vite": "^10.3.0",
    "@vitest/coverage-v8": "^4.1.0",
    "axe-core": "^4.11.1",
    "custom-elements-manifest": "^2.1.0",
    "highlight.js": "^11.11.1",
    "jsdom": "^29.0.0",
    "storybook": "^10.3.0",
    "terser": "^5.46.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "lit": "^3.3.2"
  }
}
