{
  "name": "amris",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/amris.js",
  "module": "./dist/amris.js",
  "types": "./dist/index.all.d.ts",
  "customElements": "dist/custom-elements.json",
  "exports": {
    ".": {
      "types": "./dist/index.all.d.ts",
      "import": "./dist/amris.js"
    },
    "./core": {
      "types": "./dist/index.d.ts",
      "import": "./dist/amris-core.js"
    },
    "./custom-elements.json": "./dist/custom-elements.json",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "./dist/amris.js",
    "./dist/amris-core.js"
  ],
  "scripts": {
    "dev": "vite --host",
    "build": "tsc && vite build --mode core && vite build --mode all && tsc -p tsconfig.types.json && npm run build:manifest",
    "build:manifest": "cem analyze --config custom-elements-manifest.config.js",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:a11y": "vitest run test/a11y.test.ts",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "lit": "^3.3.2"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@lit-labs/rollup-plugin-minify-html-literals": "^0.1.1",
    "@storybook/web-components": "^10.3.0",
    "@storybook/web-components-vite": "^10.3.0",
    "@vitest/coverage-v8": "^4.1.0",
    "axe-core": "^4.11.1",
    "custom-elements-manifest": "^2.1.0",
    "highlight.js": "^11.11.1",
    "jsdom": "^29.0.0",
    "storybook": "^10.3.0",
    "terser": "^5.46.1",
    "typescript": "~5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
